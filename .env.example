# Database
POSTGRES_DB=todovibe
POSTGRES_USER=todovibe
POSTGRES_PASSWORD=changeme

# Backend
DB_DSN=postgres://todovibe:changeme@db:5432/todovibe?sslmode=disable
SESSION_SECRET=replace-with-random-32-char-string
# Set to a new PIN value to reset the stored PIN on next backend startup
APP_PIN_RESET=

# Frontend (build-time)
VITE_API_BASE_URL=/api/v1
